{
    "compilerOptions": {
        "target": "ESNext",
        "jsx": "preserve",
        "lib": [
            "ESNext",
            "DOM",
            "DOM.Iterable"
        ],
        "useDefineForClassFields": true,
        "baseUrl": ".", // 查询的基础路径
        "module": "ESNext",
        /* Bundler mode */
        "moduleResolution": "node",
        "paths": {
            "@/*": [
                "src/*"
            ]
        }, // 路径映射,配合别名使用
        "resolveJsonModule": true,
        "allowImportingTsExtensions": true,
        "allowJs": false, // 允许使用js
        /* Linting */
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noEmit": true,
        "esModuleInterop": true, // 允许使用 import 引入使用 export = 导出的内容
        "isolatedModules": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.d.ts",
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.vue",
        "types/**/*.d.ts",
        "uno.config.ts",
        "vitest.config.ts",
        "vite.config.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.js"
    ]
}
