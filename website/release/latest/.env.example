# 手动部署参考配置。每个密钥请生成唯一值后注入，例如：
#   openssl rand -hex 32
# 切勿提交已生成的真实值。运行 manager.sh 会自动生成并写入 .env。

# Beacon 镜像。manager.sh 默认按主机架构选择：
#   BEACON_ARCH=amd64 -> registry.cn-hangzhou.aliyuncs.com/amuluze/beacon:v3.0.4
#   BEACON_ARCH=arm64 -> registry.cn-hangzhou.aliyuncs.com/amuluze/beacon-arm:v3.0.4
# 手动部署时可按需取消注释其中一行，或自行填写。
# BEACON_IMAGE=registry.cn-hangzhou.aliyuncs.com/amuluze/beacon:v3.0.4
# BEACON_IMAGE=registry.cn-hangzhou.aliyuncs.com/amuluze/beacon-arm:v3.0.4
BEACON_VERSION=v3.0.4
BEACON_ARCH=amd64
BEACON_CONTAINER_NAME=beacon
BEACON_HTTP_PORT=1443
BEACON_CONTROL_PORT=17000
BEACON_DATA_DIR=./data
BEACON_LOG_DIR=./logs
BEACON_DB_NAME=/app/data/beacon
BEACON_PUBLIC_BASE_URL=http://127.0.0.1:1443
BEACON_AGENT_INSTALL_TOKEN=
BEACON_AUTH_SIGNING_KEY=
BEACON_CONTROL_JOIN_TOKEN=
